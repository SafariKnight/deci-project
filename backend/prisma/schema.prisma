generator client {
  provider = "prisma-client"
  output   = "./generated/"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  username      String
  email         String         @unique
  password      String
  refreshTokens RefreshToken[]
}

model RefreshToken {
  token  String @id
  userId Int
  user   User   @relation(fields: [userId], references: [id])
}
