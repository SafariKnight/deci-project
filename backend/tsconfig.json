{
  "compilerOptions": {
    "module": "Node16",
    "target": "ESNext",
    "moduleResolution": "node16",
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "#/*": ["./src/*"]
    },
    "types": ["node", "jest"]
  }
}
